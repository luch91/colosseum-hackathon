{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2022"],
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@agentpay/sdk": ["./sdk/src/index.ts"]
    }
  },
  "include": ["tests/**/*.ts", "scripts/**/*.ts", "demo/**/*.ts"]
}
